<?xml version="1.0" encoding="UTF-8"?>
<web-app version="5.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd">

    <!-- ============ Original Servlets ============ -->
    <servlet>
        <servlet-name>HomeController</servlet-name>
        <servlet-class>controllers.HomeController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MedicineController</servlet-name>
        <servlet-class>controllers.MedicineController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MedicineDetailController</servlet-name>
        <servlet-class>controllers.MedicineDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SearchController</servlet-name>
        <servlet-class>controllers.SearchController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CartController</servlet-name>
        <servlet-class>controllers.CartController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ImportController</servlet-name>
        <servlet-class>controllers.ImportController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StaffController</servlet-name>
        <servlet-class>controllers.StaffController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MedicineAjaxController</servlet-name>
        <servlet-class>controllers.MedicineAjaxController</servlet-class>
    </servlet>

    <!-- ============ Review Servlets ============ -->
    <servlet>
        <servlet-name>View_all_owner_reviews</servlet-name>
        <servlet-class>controllers.viewAllOwnerReviewController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreatedReview</servlet-name>
        <servlet-class>controllers.createReviewController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ViewRiews</servlet-name>
        <servlet-class>controllers.viewReview</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Delete_owner_review</servlet-name>
        <servlet-class>controllers.deleteReviewController</servlet-class>
    </servlet>

    <!-- ============ Original Servlet Mappings ============ -->
    <servlet-mapping>
        <servlet-name>HomeController</servlet-name>
        <url-pattern>/home</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MedicineController</servlet-name>
        <url-pattern>/medicine</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MedicineDetailController</servlet-name>
        <url-pattern>/medicine-detail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SearchController</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CartController</servlet-name>
        <url-pattern>/cart</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ImportController</servlet-name>
        <url-pattern>/import</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StaffController</servlet-name>
        <url-pattern>/Staffmanage</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MedicineAjaxController</servlet-name>
        <url-pattern>/medicine-ajax</url-pattern>
    </servlet-mapping>

    <!-- ============ Review Servlet Mappings ============ -->
    <servlet-mapping>
        <servlet-name>View_all_owner_reviews</servlet-name>
        <url-pattern>/View_all_owner_reviews</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreatedReview</servlet-name>
        <url-pattern>/CreatedReview</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ViewRiews</servlet-name>
        <url-pattern>/ViewRiews</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Delete_owner_review</servlet-name>
        <url-pattern>/Delete_owner_review</url-pattern>
    </servlet-mapping>

    <!-- ============ Welcome File ============ -->
    <welcome-file-list>
        <welcome-file>home</welcome-file>
    </welcome-file-list>

    <!-- ============ Session Config ============ -->
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
